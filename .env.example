# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=  # Optional: set for Groq (https://api.groq.com/openai/v1) or compatible APIs
OPENAI_MODEL_NAME=gpt-4

# Elasticsearch Configuration
ELASTICSEARCH_HOST=https://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_password

# Prometheus Configuration
PROMETHEUS_URL=http://localhost:9090

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-secret

# Confluence (Runbooks)
CONFLUENCE_URL=https://your-org.atlassian.net
CONFLUENCE_EMAIL=your-email@company.com
CONFLUENCE_API_TOKEN=your-api-token

# Kubernetes
KUBECONFIG=/path/to/kubeconfig

# PagerDuty (Trigger)
PAGERDUTY_API_KEY=your-pagerduty-key

# Jira
JIRA_URL=https://your-org.atlassian.net
JIRA_USERNAME=your-username
JIRA_API_TOKEN=your-api-token

# Vector DB (for RAG - Runbooks)
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX=incident-runbooks

# Webhook Security (optional - leave empty to skip auth in dev)
WEBHOOK_SECRET=
