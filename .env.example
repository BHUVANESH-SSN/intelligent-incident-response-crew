# ── LLM ─────────────────────────────────────────────────────────────────────
# LiteLLM model strings — swap provider without touching code.
# Examples:  gpt-4o  |  anthropic/claude-sonnet-4-6  |  groq/llama3-70b-8192
LLM_MODEL=gpt-4o
LLM_MODEL_FAST=gpt-4o-mini

# Set whichever key(s) match the provider you chose above.
OPENAI_API_KEY=
OPENAI_API_BASE=          # Optional: https://api.groq.com/openai/v1 for Groq
ANTHROPIC_API_KEY=

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (dev/test)  →  sqlite:///incidents.db
# PostgreSQL (prod)  →  postgresql://user:pass@host:5432/dbname
# docker-compose overrides this automatically for the app container.
DATABASE_URL=sqlite:///incidents.db

# ── Redis ────────────────────────────────────────────────────────────────────
# Alert deduplication within a 1-hour window.
# Falls back to an in-process dict when Redis is unavailable.
REDIS_URL=redis://localhost:6379

# ── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_HOST=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# ── Prometheus ───────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090

# ── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret

# ── Jira ─────────────────────────────────────────────────────────────────────
JIRA_URL=https://your-org.atlassian.net
JIRA_USERNAME=your-email@company.com
JIRA_API_TOKEN=your-api-token
JIRA_PROJECT_KEY=INC

# ── PagerDuty ────────────────────────────────────────────────────────────────
PAGERDUTY_API_KEY=your-pagerduty-key

# ── Webhook & API security ───────────────────────────────────────────────────
# Leave both empty to skip auth in dev mode.
# WEBHOOK_SECRET — HMAC-SHA256 on inbound payloads (X-Webhook-Signature header)
# API_TOKEN      — Bearer token on GET /incidents, /incident/{id}, /metrics
WEBHOOK_SECRET=
API_TOKEN=

# ── Runtime ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development   # development | production
